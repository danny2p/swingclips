# Copy this file to .env.local and fill in your values.
# .env.local is never committed to git.

# Comma-separated list of allowed origins for local network access (no protocol, no trailing slash).
# Used to restrict which hosts can access the dev server.
# Example: 192.168.1.100,localhost:3000
ALLOWED_ORIGINS=localhost:3000

# Seconds of footage to include before the detected impact in each clip.
# Default: 2
NEXT_PUBLIC_PRE_IMPACT_SECONDS=2

# Seconds of footage to include after the detected impact in each clip.
# Default: 2
NEXT_PUBLIC_POST_IMPACT_SECONDS=2

# Thumbnail still frame offset in seconds from clip start.
# Defaults to NEXT_PUBLIC_PRE_IMPACT_SECONDS (i.e. at the moment of impact).
# Decrease to show a frame before impact; increase to show follow-through.
# Example: 1.5 = half a second before impact when PRE_IMPACT_SECONDS is 2.
NEXT_PUBLIC_THUMBNAIL_OFFSET=2.0
